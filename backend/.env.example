DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/iot_cloud

# Comma-separated origins for the dashboard (browser) frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MQTT (optional). If MQTT_BROKER is empty or MQTT_ENABLED=false, the subscriber is skipped.
MQTT_ENABLED=true
MQTT_BROKER=
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=iot/devices/data
DEBUG=false
